OLLAMA_HOST=http://localhost:11434
# Override if you want to use a different model
# OLLAMA_MODEL=qwen3.5:397b-cloud
# Or provide a comma-separated fallback list (first is primary)
# OLLAMA_MODELS=qwen3.5:397b-cloud,deepseek-v3.2:cloud,glm-5:cloud,kimi-k2.5:cloud
# Optional tuning
# OLLAMA_NUM_CTX=32768
# OLLAMA_NUM_PREDICT=12000
# OLLAMA_TEMPERATURE=0.2
# Auto-start/pull behavior (optional)
# OLLAMA_AUTO_START=true
# OLLAMA_AUTO_PULL=true
# OLLAMA_READY_TIMEOUT_MS=60000
# OLLAMA_READY_POLL_INTERVAL_MS=1000
# OLLAMA_BINARY=ollama
